# ── Configuration — Cabinet Ronron ──────────────────────────────
# Ce fichier est COMMITTÉ, c'est un choix pédagogique : la config fait
# partie du produit. Il ne contient donc QUE des valeurs de démo.
# Les vraies clés (de TEST uniquement) sont distribuées le jour J.
#
# Tant que ces valeurs restent telles quelles, l'application tourne en
# MODE DÉMO : données en mémoire, aucun service externe requis.

# Supabase — Réglages du projet > API
SUPABASE_URL=A_REMPLACER
SUPABASE_SERVICE_ROLE_KEY=A_REMPLACER

# Stripe (étape 4) — clés de TEST uniquement (sk_test_..., jamais sk_live_)
STRIPE_SECRET_KEY=A_REMPLACER
STRIPE_WEBHOOK_SECRET=A_REMPLACER

# L'URL publique de l'app (utile pour Stripe à l'étape 4)
APP_URL=http://localhost:3000
